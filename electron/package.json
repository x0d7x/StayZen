{
  "name": "stayzen",
  "version": "1.0.2",
  "description": "macOS desktop app to prevent sleep",
  "main": "dist/main/main.js",
  "author": "StayZen",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && npx electron .",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd ../frontend && npm run build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "copy-frontend": "rm -rf dist/frontend && cp -r ../frontend/dist dist/frontend",
    "package": "npm run build && npm run copy-frontend && npx electron-builder",
    "start": "npx electron ."
  },
  "build": {
    "appId": "com.stayzen.app",
    "productName": "StayZen",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "frontend/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/stayzen",
        "to": "stayzen"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "electron-log": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.8"
  }
}
